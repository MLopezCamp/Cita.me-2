{
  "dashboard": {
    "title": "cita.me - Trazabilidad por Request ID",
    "tags": ["cita.me", "observability"],
    "timezone": "browser",
    "schemaVersion": 36,
    "variables": [
      {
        "name": "request_id",
        "type": "textbox",
        "label": "Request ID",
        "query": "",
        "current": {"value": "", "text": ""}
      }
    ],
    "panels": [
      {
        "title": "🔵 API: Cita Creada",
        "type": "logs",
        "datasource": {"type": "loki", "uid": "loki"},
        "targets": [{
          "expr": "{container=\"citame-backend\"} | json | request_id=\"$request_id\" |~ \"Cita.*creada\""
        }],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "🟠 RabbitMQ: Mensaje Enviado",
        "type": "logs",
        "datasource": {"type": "loki", "uid": "loki"},
        "targets": [{
          "expr": "{container=\"citame-backend\"} | json | request_id=\"$request_id\" |~ \"Mensaje enviado\""
        }],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "🟢 Worker: Evento Procesado",
        "type": "logs",
        "datasource": {"type": "loki", "uid": "loki"},
        "targets": [{
          "expr": "{container=\"citame-worker\"} | json | request_id=\"$request_id\" |~ \"Evento procesado\""
        }],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "title": "🔴 Redis: Lock Adquirido",
        "type": "logs",
        "datasource": {"type": "loki", "uid": "loki"},
        "targets": [{
          "expr": "{container=\"citame-backend\"} | json | request_id=\"$request_id\" |~ \"Lock.*adquirido\""
        }],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "title": "📋 Flujo Completo",
        "type": "logs",
        "datasource": {"type": "loki", "uid": "loki"},
        "targets": [{
          "expr": "{container=~\"(citame-backend|citame-worker)\"} | json | request_id=\"$request_id\""
        }],
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16}
      }
    ]
  }
}