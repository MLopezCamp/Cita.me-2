# ─────────────────────────────────────────────────────────────────────────────
# cita.me — Configuracion de entorno
#
# INSTRUCCIONES:
#   1. Copiar este archivo como .env  (cp .env.example .env)
#   2. Los valores por defecto ya son funcionales para demo/pruebas.
#      Solo cambiarlos si se despliega en produccion real.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────────────────────
# Clave para firmar tokens de sesion. Este valor ya es valido para pruebas.
JWT_SECRET_KEY=IX861LyQDAByoUF3c8n2nPaIn6FwHk300sHEbczN9WA

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Docker Hub ────────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=mlopezcamp
VERSION=latest

# ── Notificaciones por email (Resend) ─────────────────────────────────────────
# Con esta clave los emails se envian a cuenta del proyecto.
# El profesor puede verificar el envio en los logs del worker:
#   docker logs citame-worker
# Para recibir emails en su propio correo: registrar cuenta en resend.com
# y reemplazar esta clave.
RESEND_API_KEY=re_HyYgZNMm_FRatQQAVS75twbmhuv84WtT6
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Grafana ───────────────────────────────────────────────────────────────────
