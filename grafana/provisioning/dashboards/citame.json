      "id": 1,
      "title": "Flujo Completo — Backend + Worker",
      "description": "Todos los logs de backend y worker filtrados por request_id. Deja vacío para ver los logs más recientes de todos los servicios.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"citame-backend|citame-worker\"} |= \"${request_id}\" | json"
        }
      ],
